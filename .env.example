# Required. Create at mit.billy.dk -> Settings -> Access tokens
BILLY_ACCESS_TOKEN=

# Optional. Auto-resolved from /organizations when omitted
BILLY_ORGANIZATION_ID=

# Optional overrides
BILLY_BASE_URL=https://api.billysbilling.com/v2
BILLY_LOCALE=en_US

# Write protection mode (default: confirm)
#   read-only - write tools are not registered at all; billy_raw_request rejects non-GET
#   confirm   - every write operation asks the END USER for approval via an MCP
#               elicitation dialog (requires a host that supports elicitation;
#               fails closed otherwise)
#   full      - writes execute without approval
BILLY_WRITE_MODE=confirm
